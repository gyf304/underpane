{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ActiveDesk",
  "version": "0.1.0",
  "identifier": "com.yifangu.activedesk",
  "build": {
    "frontendDist": "../dist-ui",
    "devUrl": "http://localhost:3000/",
    "beforeBuildCommand": "cd ../src-ui && bun install && bun run build",
    "beforeDevCommand": "cd ../src-ui && bun install && bun dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "background",
        "visible": false,
        "url": "background.html"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "./resources/": ""
    }
  }
}
